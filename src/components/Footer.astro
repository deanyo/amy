---
import SocialPill from './SocialPill.astro';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-lilac-100 bg-cream-100/60">
  <div class="container-wide py-14 grid gap-10 md:grid-cols-3 text-sm">
    <div>
      <p class="font-display text-xl text-lilac-900 font-semibold">Blackfen Little Learners</p>
      <p class="mt-3 text-ink-700/80 max-w-xs">
        Teacher-led home childminding in Blackfen, serving families across Bexley and Sidcup — a calm, nurturing setting led by a qualified primary school teacher.
      </p>
    </div>

    <div>
      <p class="eyebrow mb-3">Get in touch</p>
      <ul class="space-y-2 text-ink-700/90">
        <li><a href="tel:+447933177062" class="no-underline hover:underline">07933 177 062</a></li>
        <li><a href="mailto:amy@blackfenlittlelearners.co.uk" class="no-underline hover:underline">amy@blackfenlittlelearners.co.uk</a></li>
      </ul>
      <ul class="mt-4 flex flex-wrap gap-2 text-xs">
        <li><SocialPill network="whatsapp" href="https://wa.me/447933177062" label="WhatsApp" pillClass="pill-sage" /></li>
        <li><SocialPill network="facebook" href="https://www.facebook.com/profile.php?id=61570811308988" label="Facebook" pillClass="pill-rose" /></li>
        <li><SocialPill network="instagram" href="https://www.instagram.com/blackfenlittlelearners/" label="Instagram" /></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow mb-3">Opening</p>
      <p class="text-ink-700/90">
        Aiming for September<br />
        <span class="text-ink-700/60 text-xs">subject to Ofsted registration</span>
      </p>
      <p class="mt-3 text-xs text-ink-700/60">
        Mon–Fri · 8:00am–5:30pm · term time only
      </p>
    </div>
  </div>

  <div class="border-t border-lilac-100/70">
    <div class="container-wide py-5 flex flex-col sm:flex-row gap-2 justify-between text-xs text-ink-700/60">
      <p>© {year} Blackfen Little Learners. All rights reserved.</p>
      <p class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="/privacy/" class="no-underline hover:underline">Privacy notice</a>
        <a href="https://github.com/deanyo/amy" target="_blank" rel="noopener" class="no-underline hover:underline">Source</a>
        <span>
          Built by
          <a href="https://www.linkedin.com/in/dean-ryan-yo/" target="_blank" rel="noopener" class="no-underline hover:underline">Dean Ryan</a>
        </span>
      </p>
    </div>
  </div>
</footer>
