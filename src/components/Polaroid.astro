---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  /** Tailwind utility e.g. 'rotate-1', '-rotate-2'. Default: no rotation. */
  rotate?: string;
  /** Tailwind aspect class e.g. 'aspect-square', 'aspect-[4/5]'. */
  aspect?: string;
  /** Extra utility classes for the outer polaroid frame. */
  class?: string;
  /** Width hint for Astro's image processor — controls output sizes. */
  width?: number;
  /** Set true for above-the-fold images (eager loading). */
  priority?: boolean;
}

const {
  src,
  alt,
  caption,
  rotate = '',
  aspect = 'aspect-[4/5]',
  class: className = '',
  width = 800,
  priority = false,
} = Astro.props;
---

<figure class:list={['polaroid', rotate, className]}>
  <div class:list={['polaroid-img', aspect]}>
    <Image
      src={src}
      alt={alt}
      width={width}
      class="w-full h-full object-cover"
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      format="webp"
      quality={82}
    />
  </div>
  {caption && (
    <figcaption class="mt-4 text-center font-display text-lilac-900 text-sm">
      {caption}
    </figcaption>
  )}
</figure>
