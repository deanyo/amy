---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home', short: 'Home' },
  { href: '/about/', label: 'About', short: 'About' },
  { href: '/setting/', label: 'Our Setting', short: 'Setting' },
  { href: '/qualifications/', label: 'Qualifications', short: 'Qualified' },
  { href: '/contact/', label: 'Contact', short: 'Contact' },
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="border-b border-lilac-100 bg-cream-50/85 backdrop-blur sticky top-0 z-30">
  <div class="container-wide flex items-center justify-between py-5">
    <a href="/" class="no-underline flex items-center gap-3">
      <span aria-hidden="true" class="w-9 h-9 rounded-full bg-lilac-700 text-cream-50 flex items-center justify-center font-display font-semibold">L</span>
      <span class="flex flex-col leading-tight">
        <span class="font-display text-lg md:text-xl text-lilac-900 font-semibold">Blackfen Little Learners</span>
        <span class="text-xs text-ink-700/65 hidden sm:inline">Teacher-led childminding · Blackfen</span>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="hidden md:flex items-center gap-7 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'no-underline transition',
                isActive(l.href) ? 'text-lilac-900 font-medium' : 'text-ink-700/80 hover:text-lilac-700',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/contact/" class="btn-primary text-sm py-2 px-4 hidden sm:inline-flex">Register interest</a>
  </div>

  <nav aria-label="Mobile" class="md:hidden border-t border-lilac-100">
    <ul class="container-wide flex gap-5 overflow-x-auto py-3 text-sm">
      {links.map((l) => (
        <li class="shrink-0">
          <a
            href={l.href}
            class:list={[
              'no-underline whitespace-nowrap',
              isActive(l.href) ? 'text-lilac-900 font-medium' : 'text-ink-700/80',
            ]}
          >
            {l.short}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
