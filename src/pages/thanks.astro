---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank you · Blackfen Little Learners">
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="blob bg-lilac-200" style="width: 380px; height: 380px; top: -100px; left: -80px;"></div>
      <div class="blob bg-rose-200" style="width: 320px; height: 320px; bottom: -100px; right: -60px;"></div>
    </div>

    <div class="container-prose text-center">
      <p class="eyebrow mb-3">Enquiry sent</p>
      <h1 class="text-balance">Thank you — we'll be in touch soon.</h1>

      <p class="mt-6 text-ink-700/85 text-lg">
        Your enquiry has been received. We aim to reply within 24 hours.
      </p>

      <p class="mt-3 text-ink-700/70">
        In the meantime, feel free to follow along on Facebook or Instagram
        to see updates as we get closer to opening.
      </p>

      <div class="mt-10 flex flex-wrap gap-3 justify-center">
        <a href="https://www.facebook.com/people/Blackfen-Little-Learners/" target="_blank" rel="noopener" class="pill pill-rose no-underline">Facebook</a>
        <a href="https://www.instagram.com/blackfenlittlelearners/" target="_blank" rel="noopener" class="pill no-underline">Instagram</a>
      </div>

      <a href="/" class="btn-secondary mt-12 inline-flex">Back to home</a>
    </div>
  </section>
</Layout>
