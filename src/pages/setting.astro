---
import Layout from '../layouts/Layout.astro';
import Polaroid from '../components/Polaroid.astro';
import settingPhoto from '../assets/photos/setting.jpg';
import toysPhoto from '../assets/photos/toys1.jpg';
import booksPhoto from '../assets/photos/bookstoys1.jpg';

const features = [
  {
    title: 'Purpose-built outbuilding',
    body: 'A bright, fully insulated garden room designed specifically for childminding — separate from the family home but moments from the back door.',
    cls: 'pill',
  },
  {
    title: 'Carefully curated resources',
    body: 'Books, magnetic blocks, sensory baskets, role-play, and small-world toys, organised so children can choose freely and tidy independently.',
    cls: 'pill pill-rose',
  },
  {
    title: 'Outdoor play every day',
    body: 'Direct access to the garden, plus regular trips to local parks and woodland for fresh air, walking, and weather-led exploration.',
    cls: 'pill pill-sage',
  },
  {
    title: 'Calm, low-stimulation design',
    body: 'Neutral surfaces and natural materials so the toys and the children — not the décor — are what stand out.',
    cls: 'pill pill-sun',
  },
];
---

<Layout title="Our Setting · Blackfen Little Learners">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="blob bg-lilac-200" style="width: 360px; height: 360px; top: -100px; right: -80px;"></div>
    </div>
    <div class="container-wide pt-14 md:pt-20 pb-10">
      <p class="eyebrow mb-3">Our setting</p>
      <h1 class="max-w-3xl text-balance">A calm, purpose-built space just for our little learners.</h1>
      <p class="mt-6 text-ink-700/85 max-w-2xl">
        Our childminding takes place in a dedicated, purpose-built outbuilding
        in the family garden — designed from the ground up for safe,
        play-led early years care.
      </p>
    </div>
  </section>

  <!-- Hero photo -->
  <section class="container-wide pb-16">
    <Polaroid
      src={settingPhoto}
      alt="The purpose-built garden outbuilding under a tree, with bi-fold doors looking onto a calm interior"
      caption="The garden room"
      rotate="rotate-1"
      aspect="aspect-[16/10]"
      class="mx-auto max-w-3xl"
      priority={true}
      width={1400}
    />
  </section>

  <!-- Features -->
  <section class="py-12 md:py-16 bg-lilac-50/60">
    <div class="container-wide">
      <ul class="grid md:grid-cols-2 gap-6">
        {features.map((f) => (
          <li class="card">
            <span class:list={[f.cls, 'mb-4']}>{f.title}</span>
            <p class="text-ink-700/85">{f.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-16 md:py-20">
    <div class="container-wide">
      <div class="max-w-2xl">
        <p class="eyebrow mb-3">Gallery</p>
        <h2>Inside the setting.</h2>
        <p class="mt-4 text-ink-700/80">
          A first look at the resources and corners of our garden room.
          We'll be adding more photos as we get closer to opening.
        </p>
      </div>

      <ul class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-6">
        <li>
          <Polaroid
            src={toysPhoto}
            alt="Baskets of magnetic tiles, building blocks and wooden toys on a textured rug"
            rotate="-rotate-2"
            aspect="aspect-[4/5]"
            width={600}
          />
        </li>
        <li>
          <Polaroid
            src={booksPhoto}
            alt="Children's picture books — Julia Donaldson, Peter Rabbit, Peppa Pig — spread out on the floor"
            rotate="rotate-1"
            aspect="aspect-square"
            width={600}
          />
        </li>
        <li>
          <Polaroid
            src={settingPhoto}
            alt="Exterior of the garden outbuilding"
            rotate="rotate-2"
            aspect="aspect-[4/5]"
            width={600}
          />
        </li>
      </ul>

      <p class="mt-10 text-sm text-ink-700/60 text-center">
        More photos of the setting and resources coming soon.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="container-prose text-center">
      <h2>Want to see it for yourself?</h2>
      <p class="mt-4 text-ink-700/80">
        Once we're registered, we'd love to invite you over for a no-obligation
        visit. In the meantime, please register your interest.
      </p>
      <a href="/contact/" class="btn-primary mt-7">Register interest</a>
    </div>
  </section>
</Layout>
