---
import Layout from '../layouts/Layout.astro';
import Polaroid from '../components/Polaroid.astro';
import settingPhoto from '../assets/photos/setting.jpg';
import toysPhoto from '../assets/photos/toys1.jpg';
import booksPhoto from '../assets/photos/bookstoys1.jpg';

const heroBadges = [
  { label: 'Qualified Teacher', cls: 'pill' },
  { label: 'Early Years experience', cls: 'pill pill-rose' },
  { label: 'Term time only', cls: 'pill pill-sage' },
  { label: 'Funding accepted', cls: 'pill pill-sun' },
];

const practicalInfo = [
  { title: 'Opening',      body: 'Aiming for September',           note: 'subject to Ofsted registration', cls: 'pill-rose' },
  { title: 'Hours',        body: '8:00am – 5:30pm',                note: 'Monday to Friday',               cls: 'pill' },
  { title: 'Availability', body: 'Term time only',                 note: 'aligned with school terms',      cls: 'pill-sage' },
  { title: 'Meals',        body: 'Healthy meals & snacks',         note: 'provided as part of your day',   cls: 'pill-sun' },
  { title: 'Funding',      body: 'Government funding accepted',    note: 'Tax-Free Childcare welcome',     cls: 'pill-sky' },
  { title: 'Location',     body: 'Blackfen, southeast London',     note: 'serving Bexley & Sidcup',        cls: 'pill-peach' },
];
---

<Layout isHome>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="blob bg-lilac-200" style="width: 480px; height: 480px; top: -120px; left: -120px;"></div>
      <div class="blob bg-rose-200" style="width: 380px; height: 380px; top: 220px; right: -140px;"></div>
    </div>

    <div class="container-wide pt-14 md:pt-20 pb-16 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow mb-4">Blackfen · Coming September</p>
        <h1 class="text-balance">Teacher-led childminding in Blackfen.</h1>
        <p class="mt-6 text-ink-700/85 max-w-prose">
          A warm, nurturing home-based setting led by a qualified primary
          school teacher with extensive Early Years experience — built around
          calm routines, learning through play, and lots of time outdoors.
        </p>

        <ul class="mt-7 flex flex-wrap gap-2">
          {heroBadges.map((b) => <li class={b.cls}>{b.label}</li>)}
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="btn-primary">Register interest</a>
          <a href="/setting/" class="btn-secondary">View our setting</a>
        </div>
      </div>

      <div class="relative">
        <Polaroid
          src={settingPhoto}
          alt="The purpose-built garden outbuilding under a tree, with bi-fold doors and an egg chair"
          caption="Our setting"
          rotate="md:rotate-1"
          aspect="aspect-[4/5]"
          class="mx-auto max-w-md"
          priority={true}
          width={900}
        />
        <Polaroid
          src={toysPhoto}
          alt="Wicker baskets of wooden toys, magnetic tiles and building blocks on a soft rug"
          rotate="-rotate-6"
          aspect="aspect-square"
          class="hidden md:block absolute -bottom-6 -left-6 w-44"
          width={400}
        />
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="py-16 md:py-20">
    <div class="container-wide grid lg:grid-cols-5 gap-10 items-center">
      <div class="lg:col-span-2">
        <p class="eyebrow mb-3">Hello</p>
        <h2>A teacher's home, for your child's first big steps.</h2>
      </div>
      <div class="lg:col-span-3 text-ink-700/85 space-y-4">
        <p>
          I'm Amy — a qualified primary school teacher with extensive Early
          Years experience. After years in the classroom I'm bringing what I
          love most about teaching young children into a smaller, calmer
          home setting.
        </p>
        <p>
          Days here are built around safety, kindness, and curiosity:
          play-led learning grounded in the EYFS framework, healthy meals,
          and plenty of time in our purpose-built garden room.
        </p>
        <a href="/about/" class="inline-flex items-center text-lilac-700 font-medium no-underline hover:underline">
          More about me →
        </a>
      </div>
    </div>
  </section>

  <!-- Practical info cards -->
  <section class="py-16 md:py-20 bg-lilac-50/60 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="blob bg-sun-100" style="width: 360px; height: 360px; bottom: -80px; left: 10%;"></div>
    </div>

    <div class="container-wide">
      <div class="max-w-2xl">
        <p class="eyebrow mb-3">The practicals</p>
        <h2>Everything you need to know.</h2>
        <p class="mt-4 text-ink-700/80">
          Calm and clear from the start. Here's how a week with Blackfen
          Little Learners is set up.
        </p>
      </div>

      <ul class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {practicalInfo.map((item) => (
          <li class="card">
            <span class:list={['pill', item.cls, 'mb-4']}>{item.title}</span>
            <p class="font-display text-lg text-lilac-900">{item.body}</p>
            <p class="text-sm text-ink-700/65 mt-1">{item.note}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Setting preview -->
  <section class="py-16 md:py-20">
    <div class="container-wide grid lg:grid-cols-2 gap-12 items-center">
      <div class="grid grid-cols-2 gap-4 max-w-md">
        <Polaroid
          src={toysPhoto}
          alt="Baskets of building blocks and toys arranged on a rug"
          rotate="-rotate-2"
          aspect="aspect-square"
          class="mt-8"
          width={500}
        />
        <Polaroid
          src={booksPhoto}
          alt="A wide selection of children's picture books spread on the floor"
          rotate="rotate-2"
          aspect="aspect-[4/5]"
          width={500}
        />
        <Polaroid
          src={settingPhoto}
          alt="The garden outbuilding, viewed from across the lawn"
          rotate="rotate-1"
          aspect="aspect-[5/3]"
          class="col-span-2"
          width={900}
        />
      </div>

      <div>
        <p class="eyebrow mb-3">Our setting</p>
        <h2>A purpose-built garden room, just for the little ones.</h2>
        <p class="mt-5 text-ink-700/85">
          Our childminding space is a dedicated, purpose-built outbuilding in
          the garden — bright, safe, and stocked with carefully chosen toys,
          books, and resources for every age.
        </p>
        <p class="mt-3 text-ink-700/85">
          It's separate from the family home but only steps from the back
          door — calm, focused, and just the right size for a small group.
        </p>
        <a href="/setting/" class="btn-secondary mt-7">See more of the setting</a>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="py-16 md:py-24">
    <div class="container-prose">
      <div class="card-tinted text-center relative overflow-hidden">
        <div class="absolute inset-0 -z-10">
          <div class="blob bg-lilac-200" style="width: 280px; height: 280px; top: -80px; right: -80px;"></div>
          <div class="blob bg-rose-200" style="width: 240px; height: 240px; bottom: -80px; left: -60px;"></div>
        </div>
        <p class="eyebrow mb-3">Register interest</p>
        <h2>Looking for childcare in Blackfen?</h2>
        <p class="mt-4 text-ink-700/80 max-w-md mx-auto">
          We're taking expressions of interest now ahead of opening in
          September. Get in touch to be added to our waiting list.
        </p>
        <a href="/contact/" class="btn-primary mt-7">Get in touch</a>
      </div>
    </div>
  </section>
</Layout>
