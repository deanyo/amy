---
import Layout from '../layouts/Layout.astro';

const showError = Astro.url.searchParams.get('error') === '1';
---

<Layout title="Register Interest · Blackfen Little Learners">
  <section class="py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="blob bg-lilac-200" style="width: 380px; height: 380px; top: -120px; left: -100px;"></div>
      <div class="blob bg-rose-200" style="width: 300px; height: 300px; bottom: -80px; right: -80px;"></div>
    </div>

    <div class="container-wide grid md:grid-cols-2 gap-12 items-start">
      <div>
        <p class="eyebrow mb-3">Get in touch</p>
        <h1 class="text-balance">Let's have a chat.</h1>
        <p class="mt-6 text-ink-700/85">
          Whether you'd like to register your interest ahead of opening,
          or have a few questions, we'd love to hear from you. We aim to
          reply within 24 hours.
        </p>

        <dl class="mt-10 space-y-6">
          <div>
            <dt class="eyebrow mb-1">Phone or WhatsApp</dt>
            <dd>
              <a href="tel:+447933177062" class="text-lilac-900 font-display text-xl no-underline hover:underline">
                07933 177 062
              </a>
            </dd>
            <dd class="mt-3">
              <a
                href="https://wa.me/447933177062"
                target="_blank"
                rel="noopener"
                class="pill pill-sage no-underline inline-flex items-center gap-2"
              >
                <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                </svg>
                Message on WhatsApp
              </a>
            </dd>
          </div>
          <div>
            <dt class="eyebrow mb-1">Email</dt>
            <dd>
              <a href="mailto:amy@blackfenlittlelearners.co.uk" class="text-lilac-900 no-underline hover:underline">
                amy@blackfenlittlelearners.co.uk
              </a>
            </dd>
          </div>
          <div>
            <dt class="eyebrow mb-2">Social</dt>
            <dd class="flex flex-wrap gap-2">
              <a href="https://www.facebook.com/profile.php?id=61570811308988" target="_blank" rel="noopener" class="pill pill-rose no-underline">@Blackfen Little Learners</a>
              <a href="https://www.instagram.com/blackfenlittlelearners/" target="_blank" rel="noopener" class="pill no-underline">@blackfenlittlelearners</a>
            </dd>
          </div>
          <div>
            <dt class="eyebrow mb-1">Hours</dt>
            <dd class="text-ink-700/85">Monday – Friday, 8:00am – 5:30pm · term time only</dd>
          </div>
        </dl>
      </div>

      <form
        class="card space-y-5"
        method="POST"
        action="/api/contact"
        name="enquiry"
      >
        <h2 class="text-2xl">Register your interest</h2>

        {showError && (
          <div class="rounded-xl border border-rose-200 bg-rose-100 px-4 py-3 text-sm text-ink-700">
            Sorry — something went wrong sending that. Please check the
            form and try again, or email us directly.
          </div>
        )}

        {/* Honeypot — hidden from real users, filled by bots */}
        <div class="hidden" aria-hidden="true">
          <label for="website">Website (leave blank)</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div>
          <label for="name" class="block text-sm font-medium text-lilac-900 mb-2">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full rounded-xl border border-lilac-100 bg-cream-50 px-4 py-3 text-ink-900 focus:outline-none focus:border-lilac-500"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-lilac-900 mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full rounded-xl border border-lilac-100 bg-cream-50 px-4 py-3 text-ink-900 focus:outline-none focus:border-lilac-500"
          />
        </div>

        <div>
          <label for="child-age" class="block text-sm font-medium text-lilac-900 mb-2">
            Child's age <span class="text-ink-700/50 font-normal">(optional)</span>
          </label>
          <input
            id="child-age"
            name="child_age"
            type="text"
            placeholder="e.g. 18 months"
            class="w-full rounded-xl border border-lilac-100 bg-cream-50 px-4 py-3 text-ink-900 focus:outline-none focus:border-lilac-500"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-lilac-900 mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full rounded-xl border border-lilac-100 bg-cream-50 px-4 py-3 text-ink-900 focus:outline-none focus:border-lilac-500"
          ></textarea>
        </div>

        <button type="submit" class="btn-primary w-full">Send enquiry</button>

        <p class="text-xs text-ink-700/60">
          By submitting, you agree to Blackfen Little Learners contacting you
          about your enquiry. See our <a href="/privacy/" class="underline">privacy notice</a>.
        </p>
      </form>
    </div>
  </section>
</Layout>
