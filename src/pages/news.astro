---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Latest news · Blackfen Little Learners"
  description="A peek at what's happening at Blackfen Little Learners — follow along on Facebook for regular updates from Amy."
>
  <section class="py-16 md:py-20">
    <div class="container-prose text-center">
      <p class="eyebrow mb-3">Latest news</p>
      <h1 class="text-balance">From our Facebook page</h1>
      <p class="mt-5 text-ink-700/85">
        A peek at what's happening at Blackfen Little Learners.
        Follow along on Facebook for regular updates.
      </p>
    </div>

    <div class="container-prose mt-12">
      <div class="mx-auto max-w-[500px] overflow-hidden rounded-2xl bg-white shadow-card">
        <iframe
          src="https://www.facebook.com/plugins/post.php?href=https%3A%2F%2Fwww.facebook.com%2Fpermalink.php%3Fstory_fbid%3Dpfbid02kikNbCB1vg8qbxgr2WfGprhN8yNF5cUZoDuawz6e1M9VAVgZ9qmygbFCYiM5Z53Tl%26id%3D61570811308988&show_text=true&width=500"
          width="500"
          height="720"
          style="border:none;overflow:hidden;max-width:100%"
          scrolling="no"
          frameborder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
          loading="lazy"
          title="Latest Facebook post from Blackfen Little Learners"
        ></iframe>
      </div>

      <div class="mt-10 text-center">
        <a
          href="https://www.facebook.com/profile.php?id=61570811308988"
          target="_blank"
          rel="noopener"
          class="btn-secondary text-sm py-2 px-4"
        >
          Follow on Facebook
        </a>
      </div>
    </div>
  </section>
</Layout>
